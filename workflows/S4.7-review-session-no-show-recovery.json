        "jsonBody": "={{ JSON.stringify({ type:'Email', contactId: $('Get Contact (Entry)').first().json.contact.id, subject: \"{{contact.first_name}}, you slipped into the category insurers LOVE\\u2014because it lets them deny you instantly.\", html: \"<!DOCTYPE html>\\n<html lang=\\\"en\\\" xmlns:v=\\\"urn:schemas-microsoft-com:vml\\\">\\n<head>\\n  <meta name=\\\"x-apple-disable-message-reformatting\\\">\\n  <meta name=\\\"viewport\\\" content=\\\"width=device-width,initial-scale=1\\\">\\n  <meta http-equiv=\\\"Content-Type\\\" content=\\\"text/html; charset=UTF-8\\\">\\n  <title>{{contact.first_name}}, you slipped into the category insurers LOVE\\u2026</title>\\n  <style>\\n    @media screen and (max-width:640px){\\n      .container{width:100%!important}\\n      .stack{display:block!important;width:100%!important}\\n      .p-sm{padding:16px!important}\\n      .hide-sm{display:none!important}\\n    }\\n  </style>\\n</head>\\n<body style=\\\"margin:0; padding:0; background:#f9f9f9;\\\">\\n  <!-- Preheader (hidden) -->\\n  <div style=\\\"display:none; max-height:0; overflow:hidden; font-size:1px; line-height:1px;\\\">\\n    Missing your session didn\\u2019t cost you time. It cost you leverage. And insurers know it.\\n  </div>\\n\\n  <table role=\\\"presentation\\\" cellspacing=\\\"0\\\" cellpadding=\\\"0\\\" border=\\\"0\\\" width=\\\"100%\\\" style=\\\"background:#f9f9f9;\\\">\\n    <tr>\\n      <td align=\\\"center\\\" style=\\\"padding:24px 12px;\\\">\\n        <table role=\\\"presentation\\\" class=\\\"container\\\" cellspacing=\\\"0\\\" cellpadding=\\\"0\\\" border=\\\"0\\\" width=\\\"640\\\" style=\\\"width:640px; background:#FFFFFF; border-collapse:collapse;\\\">\\n\\n          <!-- Slim tagline bar -->\\n          <tr>\\n            <td align=\\\"center\\\" style=\\\"background:#122739; color:#CFE0EA; padding:8px 16px; font:12px/1.4 Montserrat,Arial,sans-serif; letter-spacing:.3px; text-transform:uppercase;\\\">\\n              Reece Home Protection\\n            </td>\\n          </tr>\\n\\n          <!-- Header panel -->\\n          <tr>\\n            <td style=\\\"padding:0 24px 8px 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\">\\n                <tr>\\n                  <td style=\\\"background:#f0f4f8; border-left:4px solid #ED1E24; padding:16px 16px;\\\">\\n                    <div style=\\\"font:600 12px/1.3 Montserrat,Arial,sans-serif; letter-spacing:.4px; color:#6588A0; text-transform:uppercase;\\\">Final Follow-Up</div>\\n                    <h1 style=\\\"margin:6px 0 6px; font:700 24px/1.25 Montserrat,'Helvetica Neue',Arial,sans-serif; color:#122739;\\\">\\n                      You slipped into the category insurers LOVE\\u2026\\n                    </h1>\\n                    <p style=\\\"margin:0; font:600 14px/1.5 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n                      \\u2026because it lets them deny you instantly.\\n                    </p>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n          <!-- Body copy -->\\n          <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:24px 24px 0 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">Hi {{contact.first_name}},</p>\\n              <p style=\\\"margin:0 0 16px;\\\">I\\u2019m dropping the polite filter. Because the homeowners who get hurt the worst are the ones who were handled gently until it was too late. Here\\u2019s the truth:</p>\\n            </td>\\n          </tr>\\n\\n          <!-- Key Insight Block -->\\n          <tr>\\n            <td style=\\\"padding:8px 24px 0 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\">\\n                <tr>\\n                  <td align=\\\"center\\\" style=\\\"background:#f0f4f8; border-left:4px solid #ED1E24; padding:20px 16px;\\\">\\n                     <p style=\\\"margin:0; font:700 18px/1.4 Montserrat,'Helvetica Neue',Arial,sans-serif; color:#122739; font-style:italic;\\\">\\n                      \\\"By missing your Review Session, your home remained in the single WORST classification available.\\\"\\n                    </p>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n           <!-- Body copy cont. -->\\n           <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:24px 24px 0 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">It\\u2019s called:</p>\\n            </td>\\n          </tr>\\n\\n          <!-- Status Block -->\\n          <tr>\\n            <td style=\\\"padding:8px 24px 0 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\" style=\\\"border:1px solid #eaeaea; background:#fff0f0;\\\">\\n                <tr>\\n                  <td style=\\\"padding:16px;\\\">\\n                    <p style=\\\"margin:0; font:800 22px/1.5 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#ED1E24; text-align:center;\\\">\\n                      UNVERIFIED / UNKNOWN\\n                    </p>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n           <!-- Body copy cont. -->\\n           <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:24px 24px 0 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">To insurers, that means guilty until proven compliant, lowest payout priority, highest scrutiny, and zero leverage in disputes.</p>\\n              <p style=\\\"margin:0 0 16px;\\\">A storm hits. You file a claim. The adjuster walks in *already expecting* to downgrade you. He finds one inconsistency, your classification collapses, and your payout dies in under 5 minutes.</p>\\n              <p style=\\\"margin:0 0 16px;\\\">Meanwhile, you\\u2019re standing there saying:</p>\\n            </td>\\n          </tr>\\n\\n          <!-- Quote Block -->\\n          <tr>\\n            <td style=\\\"padding:8px 24px 0 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\" style=\\\"border:1px solid #eaeaea; background:#fafafa;\\\">\\n                <tr>\\n                  <td style=\\\"padding:16px;\\\">\\n                    <p style=\\\"margin:0; font:600 15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333; text-align:center; font-style:italic;\\\">\\n                      \\u201cBut look at all the damage. Look at my policy. Look at what I paid for.\\u201d\\n                    </p>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n          <!-- Closing copy -->\\n          <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:16px 24px 24px 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">None of it matters once you\\u2019re \\u201cunverified.\\u201d This is why missing the Review Session isn\\u2019t a scheduling issue. It\\u2019s a financial vulnerability.</p>\\n              <p style=\\\"margin:0 0 16px;\\\">Here\\u2019s your last chance before I close your file:</p>\\n              <p style=\\\"margin:0 0 16px;\\\">\\ud83d\\udc49 <strong><a href=\\\"https://link.reecewindows.com/widget/bookings/home-protection-review\\\" style=\\\"color:#ED1E24; text-decoration:underline;\\\">Reschedule Your Review Session (Final)</a></strong></p>\\n              <p style=\\\"margin:0 0 16px;\\\">Or reply <strong>\\u201ccall me.\\u201d</strong></p>\\n              <p style=\\\"margin:0 0 16px;\\\">But understand this: Your insurer already has an opinion about your home. You just haven\\u2019t seen it yet.</p>\\n              <p style=\\\"margin:0 0 4px;\\\">Talk soon,</p>\\n              <p style=\\\"margin:0; font-weight:600;\\\">{{custom_values.rep_name}}<br>\\n              Home Protection Team</p>\\n            </td>\\n          </tr>\\n\\n          <!-- CTA band (final) -->\\n          <tr>\\n            <td align=\\\"center\\\" style=\\\"padding:24px; background:#122739; color:#FFFFFF;\\\">\\n              <h3 style=\\\"margin:0 0 8px; font:700 18px/1.3 Montserrat,Arial,sans-serif;\\\">Reschedule Your Session (Final)</h3>\\n              <p style=\\\"margin:0 0 16px; font:14px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif;\\\">Don't leave your home in the \\\"unverified\\\" category.</p>\\n              <!--[if mso]>\\n              <v:roundrect xmlns:v=\\\"urn:schemas-microsoft-com:vml\\\" href=\\\"https://link.reecewindows.com/widget/bookings/home-protection-review\\\" style=\\\"height:46px;v-text-anchor:middle;width:300px;\\\" arcsize=\\\"8%\\\" stroke=\\\"f\\\" fillcolor=\\\"#ED1E24\\\">\\n                <w:anchorlock/>\\n                <center style=\\\"color:#FFFFFF;font-family:Montserrat,Arial,sans-serif;font-size:16px;font-weight:700;\\\">Reschedule (Final Chance)</center>\\n              </v:roundrect>\\n              <![endif]-->\\n              <a href=\\\"https://link.reecewindows.com/widget/bookings/home-protection-review\\\"\\n                 style=\\\"background:#ED1E24; color:#FFFFFF; display:inline-block; font:700 16px/46px Montserrat,Arial,sans-serif; text-decoration:none; border-radius:6px; padding:0 20px; mso-hide:all;\\\">\\n                 Reschedule (Final Chance)\\n              </a>\\n            </td>\\n          </tr>\\n\\n          <!-- Trust band -->\\n          <tr>\\n            <td align=\\\"center\\\" style=\\\"padding:14px 16px; background:#FFFFFF; font:12px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#666666;\\\">\\n              Protecting families for over 50 years\\n            </td>\\n          </tr>\\n\\n          <!-- Footer -->\\n          <tr>\\n            <td align=\\\"center\\\" style=\\\"padding:14px 16px; background:#FFFFFF; font:12px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#666666;\\\">\\n              <div style=\\\"color:#666666;\\\">{{location.city}}, FL</div>\\n              <div><a href=\\\"{{email.unsubscribe_link}}\\\" style=\\\"color:#999999; text-decoration:underline;\\\">Unsubscribe</a> \\u2022 \\u00a9 {{right_now.year}} {{location.name}}</div>\\n            </td>\\n          </tr>\\n\\n        </table>\\n      </td>\\n    </tr>\\n  </table>\\n</body>\\n</html>\", from: \"randy@getreecewindows.com\", fromName: \"Randy Reece\" }) }}",
