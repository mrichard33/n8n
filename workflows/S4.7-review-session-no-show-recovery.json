\n            </td>\\n          </tr>\\n\\n          <!-- Header panel -->\\n          <tr>\\n            <td style=\\\"padding:0 24px 8px 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\">\\n                <tr>\\n                  <td style=\\\"background:#f0f4f8; border-left:4px solid #ED1E24; padding:16px 16px;\\\">\\n                    <div style=\\\"font:600 12px/1.3 Montserrat,Arial,sans-serif; letter-spacing:.4px; color:#6588A0; text-transform:uppercase;\\\">Following Up</div>\\n                    <h1 style=\\\"margin:6px 0 6px; font:700 24px/1.25 Montserrat,'Helvetica Neue',Arial,sans-serif; color:#122739;\\\">\\n                      Here\\u2019s the part the insurer hopes you never discover.\\n                    </h1>\\n                    <p style=\\\"margin:0; font:600 14px/1.5 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n                      Missing the session didn\\u2019t pause anything.\\n                    </p>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n          <!-- Body copy -->\\n          <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:24px 24px 0 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">Hi {{contact.first_name}},</p>\\n              <p style=\\\"margin:0 0 16px;\\\">I\\u2019m going to be more direct this time. When you missed your Review Session, one thing didn\\u2019t stop:</p>\\n            </td>\\n          </tr>\\n\\n          <!-- Key Insight Block -->\\n          <tr>\\n            <td style=\\\"padding:8px 24px 0 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\">\\n                <tr>\\n                  <td align=\\\"center\\\" style=\\\"background:#f0f4f8; border-left:4px solid #ED1E24; padding:20px 16px;\\\">\\n                     <p style=\\\"margin:0; font:700 18px/1.4 Montserrat,'Helvetica Neue',Arial,sans-serif; color:#122739; font-style:italic;\\\">\\n                      \\\"Your insurer\\u2019s internal classification system.\\\"\\n                    </p>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n           <!-- Body copy cont. -->\\n           <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:24px 24px 0 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">Your home stayed exactly where it was:</p>\\n            </td>\\n          </tr>\\n\\n          <!-- Status Block -->\\n          <tr>\\n            <td style=\\\"padding:8px 24px 0 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\" style=\\\"border:1px solid #eaeaea; background:#fafafa;\\\">\\n                <tr>\\n                  <td style=\\\"padding:16px;\\\">\\n                    <p style=\\\"margin:0; font:700 18px/1.5 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#ED1E24; text-align:center;\\\">\\n                      \\u201cUNKNOWN.\\u201d\\n                    </p>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n           <!-- Body copy cont. -->\\n           <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:24px 24px 0 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">\\u201cUnknown\\u201d isn\\u2019t neutral. It means:</p>\\n            </td>\\n          </tr>\\n\\n          <!-- Feature list card -->\\n          <tr>\\n            <td style=\\\"padding:8px 24px 0 24px; background:#FFFFFF;\\\">\\n              <table role=\\\"presentation\\\" width=\\\"100%\\\" style=\\\"border:1px solid #eaeaea; background:#fafafa;\\\">\\n                <tr>\\n                  <td style=\\\"padding:0 16px 16px 16px;\\\">\\n                    <table role=\\\"presentation\\\" width=\\\"100%\\\">\\n                      <tr>\\n                        <td width=\\\"24\\\" valign=\\\"top\\\" style=\\\"padding:8px 0; font-weight:bold; color:#ED1E24;\\\">\\u2192</td>\\n                        <td style=\\\"padding:8px 0; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\u201cWe assume there are weak links.\\u201d</td>\\n                      </tr>\\n                      <tr>\\n                        <td width=\\\"24\\\" valign=\\\"top\\\" style=\\\"padding:8px 0; font-weight:bold; color:#ED1E24;\\\">\\u2192</td>\\n                        <td style=\\\"padding:8px 0; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\u201cWe treat this home as unverified.\\u201d</td>\\n                      </tr>\\n                      <tr>\\n                        <td width=\\\"24\\\" valign=\\\"top\\\" style=\\\"padding:8px 0; font-weight:bold; color:#ED1E24;\\\">\\u2192</td>\\n                        <td style=\\\"padding:8px 0; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\u201cWe downgrade before we investigate.\\u201d</td>\\n                      </tr>\\n                    </table>\\n                  </td>\\n                </tr>\\n              </table>\\n            </td>\\n          </tr>\\n\\n          <!-- Closing copy -->\\n          <tr>\\n            <td class=\\\"p-sm\\\" style=\\\"padding:16px 24px 24px 24px; background:#FFFFFF; font:15px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#333333;\\\">\\n              <p style=\\\"margin:0 0 16px;\\\">This is where claims collapse. It's why families with new impact windows, shutters, and a good policy still get denied \\u2014 because of one unverified opening they didn\\u2019t know about.</p>\\n              <p style=\\\"margin:0 0 16px;\\\">Your Review Session is what prevents that. Let\\u2019s get you back on the calendar:</p>\\n              <p style=\\\"margin:0 0 16px;\\\">\\ud83d\\udc49 <strong><a href=\\\"https://link.reecewindows.com/widget/bookings/home-protection-review\\\" style=\\\"color:#ED1E24; text-decoration:underline;\\\">Reschedule Your Review Session</a></strong></p>\\n              <p style=\\\"margin:0 0 16px;\\\">Or if you prefer I do it manually, reply <strong>\\u201ccall me\\u201d</strong> and I\\u2019ll take care of it.</p>\\n              <p style=\\\"margin:0 0 16px;\\\">This classification doesn\\u2019t fix itself. And insurers don\\u2019t give second chances after a storm.</p>\\n              <p style=\\\"margin:0 0 4px;\\\">Talk soon,</p>\\n              <p style=\\\"margin:0; font-weight:600;\\\">{{custom_values.rep_name}}</p>\\n            </td>\\n          </tr>\\n\\n          <!-- CTA band (final) -->\\n          <tr>\\n            <td align=\\\"center\\\" style=\\\"padding:24px; background:#122739; color:#FFFFFF;\\\">\\n              <h3 style=\\\"margin:0 0 8px; font:700 18px/1.3 Montserrat,Arial,sans-serif;\\\">Reschedule Your Review Session</h3>\\n              <p style=\\\"margin:0 0 16px; font:14px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif;\\\">Don't leave your home in the \\\"unknown\\\" category.</p>\\n              <!--[if mso]>\\n              <v:roundrect xmlns:v=\\\"urn:schemas-microsoft-com:vml\\\" href=\\\"https://link.reecewindows.com/widget/bookings/home-protection-review\\\" style=\\\"height:46px;v-text-anchor:middle;width:300px;\\\" arcsize=\\\"8%\\\" stroke=\\\"f\\\" fillcolor=\\\"#ED1E24\\\">\\n                <w:anchorlock/>\\n                <center style=\\\"color:#FFFFFF;font-family:Montserrat,Arial,sans-serif;font-size:16px;font-weight:700;\\\">Reschedule My Session</center>\\n              </v:roundrect>\\n              <![endif]-->\\n              <a href=\\\"https://link.reecewindows.com/widget/bookings/home-protection-review\\\"\\n                 style=\\\"background:#ED1E24; color:#FFFFFF; display:inline-block; font:700 16px/46px Montserrat,Arial,sans-serif; text-decoration:none; border-radius:6px; padding:0 20px; mso-hide:all;\\\">\\n                 Reschedule My Session\\n              </a>\\n            </td>\\n          </tr>\\n\\n          <!-- Trust band -->\\n          <tr>\\n            <td align=\\\"center\\\" style=\\\"padding:14px 16px; background:#FFFFFF; font:12px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#666666;\\\">\\n              Protecting families for over 50 years\\n            </td>\\n          </tr>\\n\\n          <!-- Footer -->\\n          <tr>\\n            <td align=\\\"center\\\" style=\\\"padding:14px 16px; background:#FFFFFF; font:12px/1.6 -apple-system,Segoe UI,Roboto,Arial,sans-serif; color:#666666;\\\">\\n              <div style=\\\"color:#666666;\\\">{{location.city}}, FL</div>\\n              <div><a href=\\\"{{email.unsubscribe_link}}\\\" style=\\\"color:#999999; text-decoration:underline;\\\">Unsubscribe</a> \\u2022 \\u00a9 {{right_now.year}} {{location.name}}</div>\\n            </td>\\n          </tr>\\n\\n        </table>\\n      </td>\\n    </tr>\\n  </table>\\n</body>\\n</html>\", from: \"randy@getreecewindows.com\", fromName: \"Randy Reece\" }) }}",
