    {
      "id": "95f13a0f-185c-496d-842c-4439e712ffc1",
      "name": "AI: Analyze Message for Referral",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        840,
        0
      ],
      "credentials": {
        "httpMultipleHeadersAuth": {
          "id": "GS6kXBLE1ooZqLap",
          "name": "HighLevel Bearer Auth"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpMultipleHeadersAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"claude-sonnet-4-6\", \"max_tokens\": 900, \"temperature\": 0.2, \"system\": \"You are a strict message analyzer for Reece Windows & Doors referral capture. Your only job is to extract referral contact information from incoming customer messages.\\n\\nTASK\\nDetermine if the message contains BOTH a person's name AND a valid phone number.\\n\\nOUTPUT RULES\\n\\nIf BOTH a name AND a phone number are present, output exactly in this format:\\nName, Phone\\n\\nWhere:\\n- Name = the person being referred (first name, full name, or nickname \\u2014 as written in the message)\\n- Phone = 10 digits formatted as XXX-XXX-XXXX\\n- If multiple referrals are present, put each on its own line using the same format\\n\\nIf EITHER the name OR the phone is missing, output exactly:\\nNo Referral\\n\\nNAME PARSING\\n- If the message contains a full name (e.g., \\\"John Smith\\\"), output as Name only \\u2014 the parser splits it.\\n- If only a first name is given (e.g., \\\"Mike\\\"), that's fine \\u2014 output it.\\n- Keep the Name portion as written in the message.\\n\\nREQUIREMENTS\\n- Phone must be 10 US digits. Accept any format (5551234567, 555-123-4567, (555) 123-4567, 555.123.4567, 555 123 4567). Always normalize output to XXX-XXX-XXXX.\\n- 7-digit numbers, partial numbers, or non-US numbers \\u2192 treat as no phone.\\n- Generic references (\\\"my neighbor\\\", \\\"my friend\\\", \\\"a coworker\\\", \\\"someone at church\\\") without an actual name \\u2192 treat as no name.\\n- Titles alone (Mr./Mrs./Dr.) without a name \\u2192 treat as no name.\\n- Output ONLY the required format. No greetings, no explanations, no commentary, no quotes, no extra punctuation, no reasoning.\\n- Case must match exactly: \\\"No Referral\\\" (capital N, capital R).\\n\\nEXAMPLES\\n\\nInput: My neighbor John Smith - 555-123-4567\\nOutput: John Smith, 555-123-4567\\n\\nInput: Try my buddy Mike at (305) 555-1234\\nOutput: Mike, 305-555-1234\\n\\nInput: Sarah Johnson 9544441234\\nOutput: Sarah Johnson, 954-444-1234\\n\\nInput: his name is rob and number is 786.555.9988\\nOutput: rob, 786-555-9988\\n\\nInput: Send info to Tom 5551112222 and Lisa 5553334444\\nOutput: Tom, 555-111-2222\\nLisa, 555-333-4444\\n\\nInput: thanks for reaching out\\nOutput: No Referral\\n\\nInput: I have a friend who might be interested\\nOutput: No Referral\\n\\nInput: My friend Rob\\nOutput: No Referral\\n\\nInput: 555-1234\\nOutput: No Referral\\n\\nInput: call 305-555-9999 sometime\\nOutput: No Referral\\n\\nInput: Dr. Smith\\nOutput: No Referral\\n\\nInput: yeah sounds good\\nOutput: No Referral\\n\\nCRITICAL OUTPUT RULE\\nEvery referral line MUST be formatted as: Name, Phone\\nThe comma between name and phone is required.\\nDo NOT deviate from this format under any circumstance.\", \"messages\": [{\"role\": \"user\", \"content\": \"{{message.body}}\"}]}",
        "options": {}
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "c45e27c5-8c70-4fca-8f61-4b0105a11c98",
      "name": "Code: Custom Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        0
      ],
      "parameters": {
        "jsCode": "// GHL Custom Code \u2014 W12.7E Referral Extractor v3\n// Phone-first extraction \u2014 no longer requires a comma separator.\n// Input Key: aiOutput\n\nconst raw = (inputData && inputData.aiOutput) ? inputData.aiOutput.toString() : '';\n\nconst cleaned = raw.trim()\n  .replace(/^```[a-z]*\\n?/gim, '')\n  .replace(/```$/gm, '')\n  .replace(/^[\"'`]+|[\"'`]+$/g, '')\n  .trim();\n\n// Build default result with every field populated \u2014 prevents downstream merge-field errors\nconst result = {\n  hasReferral: false,\n  referralCount: 0,\n  rawOutput: cleaned,\n  allReferralsJson: '[]'\n};\nfor (let i = 1; i <= 3; i++) {\n  result[`referral${i}Name`] = '';\n  result[`referral${i}FirstName`] = '';\n  result[`referral${i}LastName`] = '';\n  result[`referral${i}Phone`] = '';\n}\n\nif (!cleaned || cleaned.toLowerCase() === 'no referral') {\n  return result;\n}\n\n// Format a 10 or 11-digit string \u2192 XXX-XXX-XXXX\nconst formatPhone = (digits) => {\n  if (digits.length === 11 && digits.startsWith('1')) digits = digits.slice(1);\n  if (digits.length !== 10) return null;\n  return `${digits.slice(0,3)}-${digits.slice(3,6)}-${digits.slice(6)}`;\n};\n\n// Name splitter \u2014 handles titles, suffixes, hyphens, single names\nconst splitName = (fullName) => {\n  const name = (fullName || '').trim();\n  if (!name) return { firstName: '', lastName: '' };\n\n  const titleStripped = name.replace(/^(mr|mrs|ms|miss|dr|sir|madam)\\.?\\s+/i, '').trim();\n  const suffixes = /\\b(jr|sr|ii|iii|iv|v|phd|md|esq)\\.?$/i;\n  const parts = titleStripped.split(/\\s+/).filter(Boolean);\n\n  if (parts.length === 0) return { firstName: '', lastName: '' };\n  if (parts.length === 1) return { firstName: parts[0], lastName: '' };\n  if (parts.length === 2) return { firstName: parts[0], lastName: parts[1] };\n\n  if (suffixes.test(parts[parts.length - 1])) {\n    return { firstName: parts[0], lastName: parts.slice(1).join(' ') };\n  }\n\n  return { firstName: parts[0], lastName: parts.slice(1).join(' ') };\n};\n\n// Match any phone-shaped thing, with or without separators/parens/country code\n// Examples that match: 5551234567 | 555-123-4567 | (555) 123-4567 | 555.123.4567\n//                     1-555-123-4567 | +1 555 123 4567\nconst phoneRegex = /(\\+?1[-.\\s]?)?\\(?(\\d{3})\\)?[-.\\s]?(\\d{3})[-.\\s]?(\\d{4})/g;\n\nconst lines = cleaned.split(/\\r?\\n/).map(l => l.trim()).filter(Boolean);\nconst referrals = [];\n\nfor (const line of lines) {\n  if (line.toLowerCase() === 'no referral') continue;\n\n  // Find the first phone pattern in the line\n  phoneRegex.lastIndex = 0;\n  const phoneMatch = phoneRegex.exec(line);\n  if (!phoneMatch) continue;\n\n  // Extract phone: groups 2+3+4 = the 10 core digits\n  const phone = formatPhone(phoneMatch[2] + phoneMatch[3] + phoneMatch[4]);\n  if (!phone) continue;\n\n  // Name = everything in the line that isn't the phone\n  // Strip the full matched phone substring, then clean up leftover punctuation\n  let name = line.replace(phoneMatch[0], '').trim();\n  // Remove trailing/leading commas, dashes, colons, \"at\", \"number is\", \"phone:\", etc.\n  name = name\n    .replace(/[,\\-:]+\\s*$/g, '')\n    .replace(/^\\s*[,\\-:]+/g, '')\n    .replace(/\\b(at|number is|phone is|phone:|number:|ph:|#)\\b/gi, '')\n    .replace(/\\s{2,}/g, ' ')\n    .trim()\n    .replace(/[,\\-:]+\\s*$/g, '')\n    .trim();\n\n  if (!name) continue;\n  if (referrals.some(r => r.phone === phone)) continue;\n\n  const { firstName, lastName } = splitName(name);\n  referrals.push({ name, firstName, lastName, phone });\n}\n\nif (referrals.length === 0) {\n  return result;\n}\n\nresult.hasReferral = true;\nresult.referralCount = referrals.length;\nresult.allReferralsJson = JSON.stringify(referrals);\n\nreferrals.slice(0, 3).forEach((r, i) => {\n  result[`referral${i + 1}Name`] = r.name;\n  result[`referral${i + 1}FirstName`] = r.firstName;\n  result[`referral${i + 1}LastName`] = r.lastName;\n  result[`referral${i + 1}Phone`] = r.phone;\n});\n\nreturn result;"
      }
    },
