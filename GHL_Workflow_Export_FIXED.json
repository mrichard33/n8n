      "parameters": {
        "jsCode": "// Get all workflows from Flatten Workflows\nconst allWorkflows = $('Flatten Workflows').all();\n\n// Get all Supabase records from previous node\nconst supabaseRecords = $('Fetch All Supabase Workflows').all();\n\n// Build a lookup map by workflow_id\nconst supabaseMap = {};\nfor (const item of supabaseRecords) {\n  const record = item.json;\n  if (record.workflow_id) {\n    supabaseMap[record.workflow_id] = record;\n  }\n}\n\n// Return all items with Supabase lookup results merged\n// Note: Hash is computed downstream by the 'Hash Payload' Crypto node\nreturn allWorkflows.map(item => {\n  const workflow = item.json;\n  const supabaseRecord = supabaseMap[workflow.workflow_id] || null;\n  \n  return {\n    json: {\n      // Original workflow data\n      location_id: workflow.location_id,\n      workflow_id: workflow.workflow_id,\n      name: workflow.name,\n      payload: workflow.payload,\n      generated_at: workflow.generated_at,\n      \n      // Supabase lookup result\n      supabase_record: supabaseRecord,\n      exists_in_supabase: !!supabaseRecord,\n      existing_hash: supabaseRecord?.hash || null\n    }\n  };\n});"
      },
