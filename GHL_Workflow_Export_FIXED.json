      "parameters": {
        "jsCode": "// Wrap workflow detail with metadata from Split In Batches\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n    // Get metadata from the Split In Batches node (via context)\n    const batchItem = $('Split In Batches').item;\n\n    results.push({\n          json: {\n                  locationId: batchItem.json.locationId,\n                  workflowId: batchItem.json.workflowId,\n                  workflowName: batchItem.json.workflowName,\n                  workflowJson: item.json\n          }\n    });\n}\n\nreturn results;\n"
      },
