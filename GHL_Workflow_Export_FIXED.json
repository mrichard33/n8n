        "jsCode": "// Get the original workflow data from Merge Workflow Data\nconst allMergedData = $('Merge Workflow Data').all();\nconst allHashData = $('Hash Payload').all();\n\nreturn $input.all().map((item, index) => {\n  // Safely get the merged data for this index\n  const mergedItem = allMergedData[index]?.json || {};\n  const hashItem = allHashData[index]?.json || {};\n  \n  return {\n    json: {\n      // Carry forward all the workflow data\n      location_id: mergedItem.location_id,\n      workflow_id: mergedItem.workflow_id,\n      name: mergedItem.name,\n      payload: mergedItem.payload,\n      generated_at: mergedItem.generated_at,\n      hash: hashItem.hash,\n      exists_in_supabase: mergedItem.exists_in_supabase,\n      existing_hash: mergedItem.existing_hash,\n      // Add upload status\n      storage_upload_success: item.json.statusCode === 200\n    }\n  };\n});"
      },
