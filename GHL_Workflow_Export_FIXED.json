      "parameters": {
        "jsCode": "// Get all workflow items from Set Export URL\nconst allWorkflows = $('Set Export URL').all();\n\n// Get all Notion pages from previous node\nconst notionPages = $input.all();\n\n// Build a lookup map by workflow_id (from Notion's 'Workflow ID' property)\nconst notionMap = {};\nfor (const page of notionPages) {\n  const props = page.json.properties || {};\n  const workflowIdProp = props['Workflow ID'];\n  if (workflowIdProp && workflowIdProp.rich_text && workflowIdProp.rich_text[0]) {\n    const workflowId = workflowIdProp.rich_text[0].plain_text;\n    notionMap[workflowId] = page.json;\n  }\n}\n\n// Return all workflow items with Notion lookup results merged\nreturn allWorkflows.map(item => {\n  const workflow = item.json;\n  const workflowId = $('Merge Workflow Data').item.json.workflow_id;\n  const notionPage = notionMap[workflowId] || null;\n  \n  return {\n    json: {\n      ...workflow,\n      notion_page: notionPage,\n      notion_page_id: notionPage?.id || null,\n      notion_hash: notionPage?.properties?.Hash?.rich_text?.[0]?.plain_text || null,\n      exists_in_notion: !!notionPage\n    }\n  };\n});"
      },
