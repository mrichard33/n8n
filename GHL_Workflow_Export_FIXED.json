        "jsCode": "const run = $input.first().json;\nconst workflows = run.workflows || [];\n\nreturn workflows.map(w => {\n  const wx = w.workflow_json || w;\n  \n  // Get the workflow JSON payload (simplified logic)\n  const payload = wx.workflowJson || null;\n\n  return {\n    json: {\n      location_id: run.locationId || wx.locationId,\n      workflow_id: wx.workflowId,\n      name: wx.workflowName,\n      payload: payload,\n      generated_at: run.generated_at,\n    }\n  };\n});"
